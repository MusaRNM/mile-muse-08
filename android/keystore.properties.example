# Copy to android/keystore.properties and fill in real values.
# This example file is safe to commit; keystore.properties itself is git-ignored.
#
# storeFile can be an absolute path or relative to the android/app/ module dir.
# Recommended: place the .jks OUTSIDE the repo (e.g. ~/keystores/miletrack-upload.jks)
# and use an absolute path so it's impossible to commit accidentally.

storeFile=/absolute/path/to/miletrack-upload.jks
storePassword=CHANGE_ME
keyAlias=miletrack
keyPassword=CHANGE_ME
