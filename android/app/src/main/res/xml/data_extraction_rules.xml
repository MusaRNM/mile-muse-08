<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (targetSdk 31+) data extraction rules. Mirrors backup_rules.xml
  and additionally blocks device-to-device transfer copies of the on-device
  trip / GPS / receipt data.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
